# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://softturn_user:softturn_password@localhost:5432/softturn_db?schema=public"

# App
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003
JWT_SECRET=softturn-dev-secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# SMTP (optional, used to send generated/reset passwords to user email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=change_me
SMTP_FROM="SoftTurn <mailer@example.com>"
